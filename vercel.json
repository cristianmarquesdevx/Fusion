{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/agendar.html", "destination": "/agendar.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  // Cron job removido temporariamente para diagnóstico.
  // O plano Hobby do Vercel limita a 1 execução/dia.
  // Reativar quando migrar para Pro ou ajustar schedule para "0 0 * * *".
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "trailingSlash": false
}
