# Fusion ERP — Variáveis de Ambiente
# =============================================
# PASSO A PASSO PARA CONFIGURAR O SUPABASE:
#
# 1. Crie um projeto em https://supabase.com
# 2. Vá em Project Settings > API e copie:
#    - Project URL → VITE_SUPABASE_URL
#    - anon public key → VITE_SUPABASE_ANON_KEY
# 3. No SQL Editor, execute o script de migração:
#    supabase/migrations/004_fusion_erp_all_in_one.sql
# 4. Vá em Authentication > Users e crie um usuário admin
# 5. Associe o usuário à tabela usuarios:
#    INSERT INTO usuarios (auth_user_id, unidade_id, nome, email, tipo)
#    VALUES ('<auth-user-id>', 'a0000000-0000-0000-0000-000000000001', 'Admin', 'admin@fusion.com', 'admin');
# 6. Vá em Database > Replication e habilite o real-time para:
#    sessoes_fila, salas, clientes, agendamentos, transacoes, estoque_items
#
# DESENVOLVIMENTO LOCAL:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores abaixo com as chaves do seu projeto Supabase
#   3. Execute: npm run dev
#
# PRODUÇÃO (Vercel):
#   Configure as variáveis abaixo no dashboard do Vercel:
#   Settings > Environment Variables

# URL do projeto Supabase (VITE_ prefix é necessário para Vite expor ao frontend)
# Encontre em: https://supabase.com -> Project Settings -> API -> Project URL
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima pública do Supabase
# Encontre em: https://supabase.com -> Project Settings -> API -> anon public
# ATENÇÃO: Esta chave é pública por design (usada no client-side)
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui
