# Fusion ERP - Variaveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# As variaveis SUPABASE_URL e SUPABASE_ANON_KEY sao usadas em producao
# pelo Vercel (configuradas no dashboard em Settings -> Environment Variables).
#
# Desenvolvimento local:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores abaixo com as chaves do seu projeto Supabase
#   3. Execute: npm run build (gera config/env.generated.js)
#   4. Ou simplesmente abra login.html no navegador (usa fallback hardcoded)

# URL do projeto Supabase
# Encontre em: https://supabase.com -> Project Settings -> API -> Project URL
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anonima publica do Supabase
# Encontre em: https://supabase.com -> Project Settings -> API -> anon public
# ATENCAO: Esta chave e publica por design (usada no client-side)
SUPABASE_ANON_KEY=sua_chave_anon_aqui
